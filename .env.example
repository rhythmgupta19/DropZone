# DropZone — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in the real values in .env
#   3. NEVER commit .env to git (it's in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────


# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-use-a-long-random-string-here


# ── Application ───────────────────────────────────────────────────────────────
# Public-facing URL used to build shareable download links.
# For local development use: http://localhost:5000
# For Render/Railway set this to your deployed URL: https://your-app.onrender.com
APP_BASE_URL=http://localhost:5000


# ── File Storage ─────────────────────────────────────────────────────────────
# Folder where uploaded files are stored (relative to project root)
UPLOAD_FOLDER=uploads

# Maximum upload size in MB (must match Flask MAX_CONTENT_LENGTH)
MAX_FILE_SIZE_MB=50


# ── File Expiry ───────────────────────────────────────────────────────────────
# Number of days before uploaded files are auto-deleted
FILE_EXPIRY_DAYS=7

# How often (in hours) the cleanup job runs to delete expired files
CLEANUP_INTERVAL_HOURS=1


# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, works out of the box — fine for small deployments):
DATABASE_URL=sqlite:///dropzone.db

# PostgreSQL (recommended for production on Render — uncomment and fill in):
# DATABASE_URL=postgresql://user:password@host:5432/dropzone


# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Folder where rotating log files are written
LOG_FOLDER=logs
